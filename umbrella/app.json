{
  "expo": {
    "name": "Umbrella",
    "slug": "umbrella",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/umbrella-logo.png",
    "scheme": "umbrella",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.antraxes.umbrella"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "AIzaSyBOJkdP2rOjEhOKCVDs7Xj0Wp-nwq4PN8M"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ddbcc7",
          "image": "./assets/images/umbrella-logo.png",
          "dark": {
            "image": "./assets/images/umbrella-logo-white.png",
            "backgroundColor": "#8f405e"
          },
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
